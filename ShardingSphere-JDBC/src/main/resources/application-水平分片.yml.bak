spring:
  application:
    # 应用名称
    name: sharging-jdbc-demo
  profiles:
    # 开发环境设置
    active: dev
  shardingsphere:
    mode:
      # 内存模式
      type: Memory

    props:
      # 打印SQl
      sql-show: true

    datasource:
      # 配置真实数据源
      names: server-user,server-order0,server-order1

      # 用户表
      server-user:
        type: com.zaxxer.hikari.HikariDataSource
        driver-class-name: com.mysql.cj.jdbc.Driver
        jdbc-url: jdbc:mysql://192.168.56.10:3320/db_user
        username: root
        password: 123456

      # 水平分库0
      server-order0:
        type: com.zaxxer.hikari.HikariDataSource
        driver-class-name: com.mysql.cj.jdbc.Driver
        jdbc-url: jdbc:mysql://192.168.56.10:3322/db_order
        username: root
        password: 123456

      # 水平分库1
      server-order1:
        type: com.zaxxer.hikari.HikariDataSource
        driver-class-name: com.mysql.cj.jdbc.Driver
        jdbc-url: jdbc:mysql://192.168.56.10:3323/db_order
        username: root
        password: 123456

    rules:
      # 数据分片
      sharding:
        tables:
          # 逻辑表名
          t_user:
            actual-data-nodes: server-user.t_user
          t_order:
            # 映射实际数据节点
            # 普通写法：server-order0.t_order0,server-order0.t_order1,server-order1.t_order0,server-order1.t_order1
            # inline表达式：
            actual-data-nodes: server-order$->{0..1}.t_order$->{0..1}
            # 分库策略
            database-strategy:
              standard:
                # 分片列名称
                sharding-column: user_id
                # 分片算法名称（行表达式）
                sharding-algorithm-name: alg_mod
            # 分表策略
            table-strategy:
              standard:
                # 分片列名称
                sharding-column: order_no
                # 分片算法名称（hash）
                sharding-algorithm-name: alg_hash_mod
            # 主键生成策略
            key-generate-strategy:
              # 分布式序列列名称
              column: id
              # 分布式序列算法名称
              key-generator-name: alg_snowflake
          t_order_item:
            actual-data-nodes: server-order$->{0..1}.t_order_item$->{0..1}
            # 分库策略
            database-strategy:
              standard:
                # 分片列名称
                sharding-column: user_id
                # 分片算法名称
                sharding-algorithm-name: alg_mod
            #  分表策略
            table-strategy:
              standard:
                # 分片列名称
                sharding-column: order_no
                # 分片算法名称
                sharding-algorithm-name: alg_hash_mod
            # 分布式序列策略配置
            key-generate-strategy:
              # 分布式序列列名称
              column: id
              # 分布式序列算法名称
              key-generator-name: alg_snowflake
          # 数据节点可不配置，默认情况下，向所有数据源广播
          t_dict:
            actual-data-nodes: server-user.t_dict,server-order$->{0..1}.t_dict
        # 分片算法配置
        sharding-algorithms:
          # 行表达式分片算法
          alg_inline_userid:
            # 行表达式分片算法
            type: INLINE
            # 分片算法属性配置
            props:
              algorithm-expression: server-order$->{user_id % 2}
          alg_mod:
            # 取模分片算法
            type: MOD
            # 分片算法属性配置
            props:
              sharding-count: 2
          alg_hash_mod:
            # 哈希分片算法
            type: HASH_MOD
            # 分片算法属性配置
            props:
              sharding-count: 2

        # 主键生成逻辑
        key-generators:
          # 分布式序列算法配置
          alg_snowflake:
            # 分布式序列算法类型 - 雪花算法
            type: SNOWFLAKE
            # 分布式序列算法属性配置（当主键是分片列时，建议配置属性[参考文档 ]）
          #            props:

        # 绑定表
        binding-tables:
          # 被绑定的是逻辑表名
          # 如果没有配置绑定表，关联查询产生的实际SQL个数为笛卡尔积个数
          # 如果配置了绑定表，关联查询产生的实际SQL个数会减少为分片表数 * 分片库数
          # 在关联查询中，要求关联字段必须是分片字段，例如t_order.order_no = t_order_item.order_no
          - t_order,t_order_item

        # 广播表
        broadcast-tables:
          - t_dict
